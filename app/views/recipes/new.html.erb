<div class="container">

  <%= simple_form_for @recipe do |f| %>
    <%= f.input :title %>
    <%= f.input :description %>
    <h3>Ingrédients</h3>
    <div id='recipe-ingredients'>
      <%= f.simple_fields_for :recipe_ingredients do |ri| %>
        <%= render 'recipe_ingredient_fields', :f => ri %>
      <% end %>
      <div class='links'>
        <%= link_to_add_association 'Ajouter un ingrédient', f, :recipe_ingredients %>
      </div>
    </div>
    <%= f.input :instruction %>
    <%= f.input :image %>
    <%= f.submit 'Save' %>
  <% end %>

</div>
